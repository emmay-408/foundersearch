<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Founder Brief Generator — Emergence Capital</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ec-navy: #1B3A5C;
    --ec-teal: #2E86AB;
    --ec-teal-light: #EAF5FB;
    --ec-teal-mid: #B8DFF0;
    --bg: #F7F6F3;
    --surface: #FFFFFF;
    --border: #E2E0DA;
    --text-primary: #1A1916;
    --text-secondary: #6B6960;
    --text-muted: #9B9890;
    --accent: #2E86AB;
    --success-bg: #EAF5EB;
    --success-border: #A8D5AB;
    --flag-bg: #FFF8EC;
    --flag-border: #F5D78E;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text-primary);
    min-height: 100vh;
    padding: 0;
  }

  .header {
    background: var(--ec-navy);
    padding: 24px 40px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .logo-mark {
    width: 36px;
    height: 36px;
    background: var(--ec-teal);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-mark svg { width: 22px; height: 22px; }

  .header-text h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 18px;
    color: #FFFFFF;
    letter-spacing: -0.2px;
  }

  .header-text p {
    font-size: 12px;
    color: rgba(255,255,255,0.55);
    margin-top: 2px;
    font-weight: 300;
  }

  .main {
    max-width: 860px;
    margin: 0 auto;
    padding: 40px 24px 80px;
  }

  .input-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 32px;
  }

  .input-card h2 {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    color: var(--ec-navy);
    margin-bottom: 6px;
  }

  .input-card p {
    font-size: 14px;
    color: var(--text-secondary);
    margin-bottom: 28px;
    line-height: 1.6;
  }

  .fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }

  .field label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 8px;
  }

  .field input {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text-primary);
    background: var(--bg);
    outline: none;
    transition: border-color 0.15s;
  }

  .field input:focus {
    border-color: var(--ec-teal);
    background: var(--surface);
  }

  .field input::placeholder { color: var(--text-muted); }

  .context-row {
    margin-bottom: 20px;
  }

  .context-row label {
    display: block;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    margin-bottom: 8px;
  }

  .context-row textarea {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text-primary);
    background: var(--bg);
    outline: none;
    resize: vertical;
    min-height: 80px;
    transition: border-color 0.15s;
    line-height: 1.5;
  }

  .context-row textarea:focus {
    border-color: var(--ec-teal);
    background: var(--surface);
  }

  .context-row textarea::placeholder { color: var(--text-muted); }

  .generate-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--ec-navy);
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    padding: 13px 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }

  .generate-btn:hover { background: #243f63; }
  .generate-btn:active { transform: scale(0.98); }
  .generate-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .generate-btn .spinner {
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: #fff;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    display: none;
  }

  .generate-btn.loading .spinner { display: block; }
  .generate-btn.loading .btn-icon { display: none; }

  @keyframes spin { to { transform: rotate(360deg); } }

  .status-bar {
    display: none;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background: var(--ec-teal-light);
    border: 1px solid var(--ec-teal-mid);
    border-radius: 10px;
    margin-top: 16px;
    font-size: 13px;
    color: var(--ec-navy);
  }

  .status-bar.visible { display: flex; }

  .status-dot {
    width: 8px;
    height: 8px;
    background: var(--ec-teal);
    border-radius: 50%;
    animation: pulse 1.2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .brief-output {
    display: none;
  }

  .brief-output.visible { display: block; }

  .brief-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 24px;
    gap: 16px;
  }

  .brief-title h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 26px;
    color: var(--ec-navy);
  }

  .brief-title .company-tag {
    display: inline-block;
    margin-top: 6px;
    padding: 4px 12px;
    background: var(--ec-teal-light);
    border: 1px solid var(--ec-teal-mid);
    border-radius: 20px;
    font-size: 12px;
    color: var(--ec-teal);
    font-weight: 500;
  }

  .brief-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .meta-badge {
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 500;
    background: #F1EFE8;
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  .copy-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .copy-btn:hover { background: var(--bg); border-color: var(--ec-teal); color: var(--ec-teal); }

  .sections-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .section-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .section-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border);
    background: #FAFAF8;
  }

  .section-icon {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    flex-shrink: 0;
  }

  .section-icon.navy { background: var(--ec-navy); }
  .section-icon.teal { background: var(--ec-teal-light); border: 1px solid var(--ec-teal-mid); }
  .section-icon.amber { background: #FFF8EC; border: 1px solid #F5D78E; }
  .section-icon.green { background: var(--success-bg); border: 1px solid var(--success-border); }

  .section-card-header h4 {
    font-size: 13px;
    font-weight: 500;
    color: var(--ec-navy);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .section-card-body {
    padding: 18px 20px;
    font-size: 14px;
    line-height: 1.75;
    color: var(--text-primary);
  }

  .section-card-body p { margin-bottom: 8px; }
  .section-card-body p:last-child { margin-bottom: 0; }

  .section-card-body ul {
    list-style: none;
    padding: 0;
  }

  .section-card-body ul li {
    padding: 6px 0 6px 18px;
    position: relative;
    border-bottom: 1px solid var(--border);
    font-size: 14px;
    line-height: 1.6;
  }

  .section-card-body ul li:last-child { border-bottom: none; }

  .section-card-body ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ec-teal);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .highlight-item {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px;
  }

  .highlight-num {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    color: var(--ec-teal);
    line-height: 1;
    margin-bottom: 8px;
  }

  .highlight-text {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-primary);
  }

  .flag-card {
    background: var(--flag-bg);
    border: 1px solid var(--flag-border);
    border-radius: 10px;
    padding: 14px 16px;
    font-size: 13px;
    line-height: 1.6;
    color: #6B5000;
  }

  .convo-starters { display: flex; flex-direction: column; gap: 10px; }

  .convo-starter {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    background: var(--ec-teal-light);
    border: 1px solid var(--ec-teal-mid);
    border-radius: 10px;
    padding: 12px 14px;
  }

  .convo-q {
    font-size: 18px;
    color: var(--ec-teal);
    flex-shrink: 0;
    line-height: 1.3;
  }

  .convo-text { font-size: 13px; line-height: 1.6; color: var(--ec-navy); }

  .new-brief-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 11px 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.15s;
  }

  .new-brief-btn:hover { border-color: var(--ec-navy); color: var(--ec-navy); }

  .error-card {
    background: #FEF2F2;
    border: 1px solid #FCA5A5;
    border-radius: 12px;
    padding: 20px 24px;
    font-size: 14px;
    color: #991B1B;
    line-height: 1.6;
  }

  .prompt-tip {
    margin-top: 20px;
    padding: 12px 16px;
    background: #F7F6F3;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .prompt-tip strong { color: var(--text-secondary); }

  @media (max-width: 600px) {
    .fields { grid-template-columns: 1fr; }
    .highlights-grid { grid-template-columns: 1fr; }
    .header { padding: 18px 20px; }
    .main { padding: 24px 16px 60px; }
    .input-card { padding: 20px; }
  }
</style>
</head>
<body>

<div class="header">
  <div class="logo-mark">
    <svg viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="3" y="3" width="7" height="7" rx="1.5" fill="white"/>
      <rect x="12" y="3" width="7" height="7" rx="1.5" fill="white" opacity="0.5"/>
      <rect x="3" y="12" width="7" height="7" rx="1.5" fill="white" opacity="0.5"/>
      <rect x="12" y="12" width="7" height="7" rx="1.5" fill="white" opacity="0.7"/>
    </svg>
  </div>
  <div class="header-text">
    <h1>Founder Brief Generator</h1>
    <p>Emergence Capital · Pre-meeting research, powered by AI</p>
  </div>
</div>

<div class="main">

  <div class="input-card" id="input-section">
    <h2>Generate a founder brief</h2>
    <p>Enter a founder's name and company below. The AI will search the web and produce a structured pre-meeting brief for Yaz to review in the 5 minutes before the call.</p>

    <div class="fields">
      <div class="field">
        <label>Founder name</label>
        <input type="text" id="founder-name" placeholder="e.g. Zain Asgar" />
      </div>
      <div class="field">
        <label>Company</label>
        <input type="text" id="company-name" placeholder="e.g. Gimlet" />
      </div>
    </div>

    <div class="context-row">
      <label>Additional context (optional)</label>
      <textarea id="extra-context" placeholder="e.g. Intro'd by Benchmark. Focus on their GTM approach. Yaz has a connection to their lead investor..."></textarea>
    </div>

    <button class="generate-btn" id="generate-btn" onclick="generateBrief()">
      <svg class="btn-icon" width="16" height="16" viewBox="0 0 16 16" fill="none">
        <path d="M8 1.5L9.5 6H14L10.5 8.5L12 13L8 10.5L4 13L5.5 8.5L2 6H6.5L8 1.5Z" fill="white"/>
      </svg>
      <div class="spinner"></div>
      Generate brief
    </button>

    <div class="status-bar" id="status-bar">
      <div class="status-dot"></div>
      <span id="status-text">Searching the web and generating brief...</span>
    </div>

    <div class="prompt-tip">
      <strong>How it works:</strong> This tool uses Claude with live web search to pull the latest information on the founder and company — funding rounds, recent news, Emergence connections, and conversation starters. The same prompt runs every time, so briefs are consistent and repeatable.
    </div>
  </div>

  <div class="brief-output" id="brief-output">
    <div class="brief-header">
      <div class="brief-title">
        <h3 id="out-name">—</h3>
        <span class="company-tag" id="out-company">—</span>
      </div>
      <button class="copy-btn" onclick="copyBrief()">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <rect x="4" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/>
          <path d="M2 10V2h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
        </svg>
        Copy brief
      </button>
    </div>

    <div class="sections-grid" id="sections-grid">
    </div>

    <button class="new-brief-btn" onclick="resetForm()">
      ← Generate another brief
    </button>
  </div>

  <div id="error-output"></div>

</div>

<script>
const SYSTEM_PROMPT = `You are an expert research assistant for Yaz El-Baba, a Partner at Emergence Capital (Series A/B enterprise software and AI infrastructure VC). Your job is to produce a structured pre-meeting brief that Yaz can read in 5 minutes before meeting a founder for the first time.

Emergence Capital context:
- Focus: Series A/B enterprise software, AI infrastructure, developer tools, security, and cloud
- Portfolio includes: Zoom, Salesforce, Box, Veeva, Bladework (Bland AI)
- Yaz's background: Former LinkedIn, first associate-to-partner at Emergence, known for early career talent focus and Middle Eastern founder community support
- The EA (Emma) uses this tool to prep Yaz for every new founder meeting

Output ONLY valid JSON in this exact structure (no markdown, no backticks, no preamble):
{
  "founder": "Full name",
  "company": "Company name",
  "stage": "Stage (e.g. Seed, Series A)",
  "sector": "Sector",
  "who_they_are": "2-3 sentence summary of founder background, career path, education, and what makes them notable. Be specific.",
  "what_they_build": "2-3 sentence description of the company, product, what problem it solves, and traction/scale if known.",
  "funding": {
    "last_round": "Round name or Unknown",
    "amount": "Amount or Unknown",
    "lead_investor": "Lead investor or Unknown",
    "date": "Date or Unknown",
    "total_raised": "Total raised or Unknown"
  },
  "emergence_connections": "Specific overlaps between this founder/company and Emergence or Yaz. Cover: shared investors, portfolio company overlaps, university ties, past companies, mutual connections in the VC ecosystem, or sector alignment. Be specific. If nothing found, say so honestly.",
  "highlights": [
    "Highlight 1 — specific, interesting, useful for conversation. Include data points where possible.",
    "Highlight 2 — a different angle: team, product, market, recent news, or competitive position.",
    "Highlight 3 — something Yaz should congratulate them on or a hook for the conversation."
  ],
  "conversation_starters": [
    "A specific, thoughtful opening question based on recent news or something unique about their journey.",
    "A second opener tied to Emergence's portfolio or Yaz's background that creates a natural connection.",
    "A third that probes their vision or a strategic question worth exploring."
  ],
  "open_questions": "1-2 things worth probing: gaps in the story, competitive dynamics, burn/business model questions, or anything that warrants deeper diligence. Keep it sharp and honest."
}`;

async function generateBrief() {
  const founderName = document.getElementById('founder-name').value.trim();
  const companyName = document.getElementById('company-name').value.trim();
  const extraContext = document.getElementById('extra-context').value.trim();

  if (!founderName || !companyName) {
    alert('Please enter both a founder name and company.');
    return;
  }

  const btn = document.getElementById('generate-btn');
  const statusBar = document.getElementById('status-bar');
  const statusText = document.getElementById('status-text');

  btn.disabled = true;
  btn.classList.add('loading');
  statusBar.classList.add('visible');
  document.getElementById('error-output').innerHTML = '';

  const statuses = [
    `Searching for ${founderName} and ${companyName}...`,
    'Pulling funding history and investor data...',
    'Finding Emergence connections and overlaps...',
    'Synthesizing brief...'
  ];

  let si = 0;
  const statusInterval = setInterval(() => {
    si = (si + 1) % statuses.length;
    statusText.textContent = statuses[si];
  }, 2200);

  const userMessage = `Research ${founderName}, founder of ${companyName}. Use web search to find the most current information available. ${extraContext ? 'Additional context from the EA: ' + extraContext : ''} Generate the pre-meeting brief following the exact JSON structure specified.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        tools: [{ type: 'web_search_20250305', name: 'web_search' }],
        messages: [{ role: 'user', content: userMessage }]
      })
    });

    clearInterval(statusInterval);

    if (!response.ok) {
      throw new Error(`API error: ${response.status}`);
    }

    const data = await response.json();

    const textBlock = data.content.find(b => b.type === 'text');
    if (!textBlock) throw new Error('No text response from API');

    let raw = textBlock.text.trim();
    raw = raw.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();

    const jsonStart = raw.indexOf('{');
    const jsonEnd = raw.lastIndexOf('}');
    if (jsonStart === -1 || jsonEnd === -1) throw new Error('Could not parse JSON response');
    raw = raw.slice(jsonStart, jsonEnd + 1);

    const brief = JSON.parse(raw);
    renderBrief(brief);

  } catch (err) {
    clearInterval(statusInterval);
    document.getElementById('error-output').innerHTML = `
      <div class="error-card">
        <strong>Something went wrong.</strong><br>
        ${err.message}. Please check your connection and try again.
      </div>`;
  } finally {
    btn.disabled = false;
    btn.classList.remove('loading');
    statusBar.classList.remove('visible');
  }
}

function renderBrief(brief) {
  document.getElementById('out-name').textContent = brief.founder || '—';
  document.getElementById('out-company').textContent = brief.company || '—';

  const grid = document.getElementById('sections-grid');
  grid.innerHTML = '';

  const fundingLines = [
    brief.funding.last_round !== 'Unknown' ? `<li><strong>Round:</strong> ${brief.funding.last_round}</li>` : '',
    brief.funding.amount !== 'Unknown' ? `<li><strong>Amount:</strong> ${brief.funding.amount}</li>` : '',
    brief.funding.total_raised !== 'Unknown' ? `<li><strong>Total raised:</strong> ${brief.funding.total_raised}</li>` : '',
    brief.funding.lead_investor !== 'Unknown' ? `<li><strong>Lead:</strong> ${brief.funding.lead_investor}</li>` : '',
    brief.funding.date !== 'Unknown' ? `<li><strong>Date:</strong> ${brief.funding.date}</li>` : '',
  ].filter(Boolean).join('');

  const sections = [
    {
      icon: '👤', iconClass: 'navy', label: 'Who they are',
      content: `<p>${brief.who_they_are}</p>`,
    },
    {
      icon: '🏗', iconClass: 'teal', label: 'What they\'re building',
      content: `<p>${brief.what_they_build}</p>`,
    },
    {
      icon: '💰', iconClass: 'green', label: 'Funding',
      content: fundingLines ? `<ul>${fundingLines}</ul>` : '<p>No public funding data found.</p>',
    },
    {
      icon: '🔗', iconClass: 'teal', label: 'Emergence connections',
      content: `<p>${brief.emergence_connections}</p>`,
    },
    {
      icon: '⭐', iconClass: 'amber', label: '3 highlights',
      content: `<div class="highlights-grid">${(brief.highlights || []).map((h, i) => `
        <div class="highlight-item">
          <div class="highlight-num">${i + 1}</div>
          <div class="highlight-text">${h}</div>
        </div>`).join('')}</div>`,
    },
    {
      icon: '💬', iconClass: 'teal', label: 'Conversation starters',
      content: `<div class="convo-starters">${(brief.conversation_starters || []).map(s => `
        <div class="convo-starter">
          <span class="convo-q">"</span>
          <span class="convo-text">${s}</span>
        </div>`).join('')}</div>`,
    },
    {
      icon: '🔍', iconClass: 'amber', label: 'Open questions / things to probe',
      content: `<div class="flag-card">${brief.open_questions}</div>`,
    },
  ];

  sections.forEach(s => {
    grid.innerHTML += `
      <div class="section-card">
        <div class="section-card-header">
          <div class="section-icon ${s.iconClass}" style="font-size:14px; display:flex; align-items:center; justify-content:center;">${s.icon}</div>
          <h4>${s.label}</h4>
        </div>
        <div class="section-card-body">${s.content}</div>
      </div>`;
  });

  document.getElementById('input-section').style.display = 'none';
  document.getElementById('brief-output').classList.add('visible');
  window.currentBrief = brief;
}

function copyBrief() {
  if (!window.currentBrief) return;
  const b = window.currentBrief;
  const text = [
    `FOUNDER BRIEF — ${b.founder} / ${b.company}`,
    `Stage: ${b.stage} | Sector: ${b.sector}`,
    '',
    'WHO THEY ARE',
    b.who_they_are,
    '',
    "WHAT THEY'RE BUILDING",
    b.what_they_build,
    '',
    'FUNDING',
    `Last round: ${b.funding.last_round} | Amount: ${b.funding.amount} | Lead: ${b.funding.lead_investor} | Date: ${b.funding.date} | Total: ${b.funding.total_raised}`,
    '',
    'EMERGENCE CONNECTIONS',
    b.emergence_connections,
    '',
    '3 HIGHLIGHTS',
    ...(b.highlights || []).map((h, i) => `${i+1}. ${h}`),
    '',
    'CONVERSATION STARTERS',
    ...(b.conversation_starters || []).map((s, i) => `${i+1}. "${s}"`),
    '',
    'OPEN QUESTIONS',
    b.open_questions,
  ].join('\n');

  navigator.clipboard.writeText(text).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="4" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M2 10V2h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg> Copy brief'; }, 2000);
  });
}

function resetForm() {
  document.getElementById('input-section').style.display = 'block';
  document.getElementById('brief-output').classList.remove('visible');
  document.getElementById('founder-name').value = '';
  document.getElementById('company-name').value = '';
  document.getElementById('extra-context').value = '';
  window.currentBrief = null;
}

document.getElementById('founder-name').addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('company-name').focus(); });
document.getElementById('company-name').addEventListener('keydown', e => { if (e.key === 'Enter') generateBrief(); });
</script>
</body>
</html>
